#!/usr/bin/env bash
# Run E2E on the current machine only.
# Linux/Windows VMs: clone repo inside guest and use the per-OS script there.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

BUILD=0

usage() {
  cat <<'EOF'
Usage: ./run-all-e2e [options] [-- playwright-args...]

Runs E2E on THIS machine (no SSH, no UTM orchestration).

  macOS host  -> scripts/e2e/run-macos-e2e.sh
  Linux host  -> scripts/e2e/run-linux-e2e.sh (ubuntu/arch auto-detect)
  Windows     -> run scripts/e2e/run-windows-e2e.ps1 inside the VM

Inside VMs (after git pull):
  ./scripts/e2e/run-ubuntu-e2e.sh
  ./scripts/e2e/run-arch-e2e.sh
  .\scripts\e2e\run-windows-e2e.ps1

Options:
  --build         npm run build before E2E (packaged app mode)
  --backend-only  Skip packaged app; run Python sidecar only (fast dev)
  -h, --help      Show help

One-time VM setup: docs/e2e-vm-setup.md
EOF
}

PLAYWRIGHT_ARGS=()
while (($#)); do
  case "$1" in
    --build) BUILD=1; shift ;;
    --backend-only) export E2E_BACKEND_ONLY=1; shift ;;
    -h | --help) usage; exit 0 ;;
    --)
      shift
      PLAYWRIGHT_ARGS=("$@")
      break
      ;;
    *)
      PLAYWRIGHT_ARGS=("$@")
      break
      ;;
  esac
done

if [[ "$BUILD" == "1" && "${E2E_BACKEND_ONLY:-0}" != "1" ]]; then
  if [[ ! -d venv ]]; then
    echo "run-all-e2e: venv/ missing" >&2
    exit 1
  fi
  source venv/bin/activate
  echo "run-all-e2e: building packaged app..."
  npm run build
fi

case "$(uname -s)" in
  Darwin)
    bash scripts/e2e/run-macos-e2e.sh "${PLAYWRIGHT_ARGS[@]:-}"
    ;;
  Linux)
    bash scripts/e2e/run-linux-e2e.sh "${PLAYWRIGHT_ARGS[@]:-}"
    ;;
  MINGW* | MSYS* | CYGWIN* | Windows*)
    echo "run-all-e2e: use PowerShell inside Windows VM:" >&2
    echo "  .\\scripts\\e2e\\run-windows-e2e.ps1" >&2
    exit 1
    ;;
  *)
    echo "run-all-e2e: unsupported OS $(uname -s)" >&2
    exit 1
    ;;
esac

echo "run-all-e2e: PASS"
