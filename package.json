{
  "name": "dronmakr",
  "version": "0.57.5",
  "private": true,
  "description": "dronmakr desktop app",
  "scripts": {
    "build:frontend": "python scripts/build_frontend.py",
    "build:sidecar": "bash scripts/build_sidecar.sh",
    "icons": "bash scripts/build_mac_app_icns.sh",
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:backend": "python backend/backend_server.py --port 3766 --dev-frontend",
    "build": "npm run build:frontend && npm run build:sidecar && tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
