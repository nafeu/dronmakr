{
  "name": "dronmakr",
  "version": "0.58.11",
  "private": true,
  "description": "dronmakr desktop app",
  "license": "GPL-3.0-only",
  "scripts": {
    "build:frontend": "python scripts/build_frontend.py",
    "build:sidecar": "bash scripts/build_sidecar.sh",
    "icons": "bash scripts/build_mac_app_icns.sh",
    "icons:windows": "python scripts/build_windows_app_ico.py",
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:backend": "bash scripts/dev_backend.sh",
    "build": "npm run build:frontend && npm run build:sidecar && tauri build",
    "build:linux": "bash scripts/build_linux.sh",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.2",
    "typescript": "^5.8.2"
  }
}
