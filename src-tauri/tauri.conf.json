{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dronmakr",
  "version": "0.56.0",
  "identifier": "io.github.nafeu.dronmakr",
  "build": {
    "beforeDevCommand": "python backend/backend_server.py --port 3766 --dev-frontend",
    "devUrl": "http://127.0.0.1:3766",
    "beforeBuildCommand": "python scripts/build_frontend.py",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "dronmakr",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 720,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/dronmakr-backend"
    ],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "macos-fps": {
      "enabled": true
    }
  }
}
